{
  "name": "semantic-search-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync(require('path').join(process.cwd(),'.next'),{recursive:true,force:true}); console.log('Removed .next')\"",
    "predev": "npm run build:sdk",
    "prebuild": "npm run build:sdk",
    "build:sdk": "npm run build --prefix ../sdk",
    "dev": "next dev -p 3200 -H 0.0.0.0",
    "dev:clean": "npm run clean && npm run dev",
    "build": "next build",
    "start": "next start -p 3200"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "next": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semantic-search-sdk": "file:../sdk"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
